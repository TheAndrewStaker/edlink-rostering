# EdLink Rostering — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Database ─────────────────────────────────────────────────────────
# Async Postgres URLs. APP is used by the sync worker; OPS is used by
# the CLI and admin API. In dev, both point at the same database.
# DATABASE_URL is a legacy fallback — set it if you want a single URL
# for both roles.
APP_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/edlink_poc
OPS_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/edlink_poc
MIGRATION_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/edlink_poc

# ── Ports ────────────────────────────────────────────────────────────
# Deterministic port base. PORT_API = BASE, PORT_WEB = BASE + 1.
# Change the base to run multiple checkouts side by side.
EDLINK_PORT_BASE=8100
PORT_POSTGRES=5434

# ── Profile ──────────────────────────────────────────────────────────
# Set to "dev" to enable dev-only routes (persona switcher, test events).
# Leave empty or unset for production behavior.
EDLINK_PROFILE=dev

# ── Auth ─────────────────────────────────────────────────────────────
# HS256 signing secret for dev JWT minting. Only used when
# EDLINK_PROFILE=dev. Production uses JWKS-backed RS256.
DEV_JWT_SECRET=dev-secret-do-not-use-in-production

# ── Key Vault (mock) ────────────────────────────────────────────────
# Per-LEA EdLink bearer tokens. The mock Key Vault reads env vars
# prefixed with KEYVAULT__ and exposes them as secrets. Name format:
# KEYVAULT__EDLINK_TOKEN_LEA_<lea_id> (double underscore after KEYVAULT).
# Example:
# KEYVAULT__EDLINK_TOKEN_LEA_NORTHRIDGE=bearer-token-here

# E2E test token used by Playwright specs.
KEYVAULT__E2E_TEST_TOKEN=e2e-test-token

# ── Production provider config (leave unset for dev) ────────────────
# Setting any of these activates the real provider in place of the
# dev mock. See edlink_rostering/api/dependencies.py for the switch.

# Azure Key Vault
# AZURE_KEYVAULT_URL=https://my-vault.vault.azure.net/

# Azure Application Insights
# APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Azure Service Bus
# SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...
# SERVICE_BUS_QUEUE_NAME=rostering-events

# JWT / IdP (RS256 JWKS validation)
# JWKS_URL=https://login.microsoftonline.com/.../discovery/v2.0/keys
# JWT_ISSUER=https://login.microsoftonline.com/.../v2.0
# JWT_AUDIENCE=api://edlink-rostering
